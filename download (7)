              );
            })}
          </nav>

          <div className="flex-1 min-w-0">
            {/* Mobile section tabs */}
            <div className="flex md:hidden gap-2 overflow-x-auto pb-4 -mx-1 px-1">
              {SECTIONS.map((s) => (
                <button
                  key={s.key}
                  onClick={() => setActive(s.key)}
                  className="flex-shrink-0 text-xs font-semibold px-3.5 py-2 rounded-full"
                  style={{ background: active === s.key ? NAVY : "white", color: active === s.key ? "white" : "#5b6572" }}
