function Label({ children }) {
  return <label className="text-xs font-semibold uppercase tracking-wide" style={{ color: "#9AA3AF" }}>{children}</label>;
}

function Input({ value, onChange, placeholder, type = "text" }) {
  return (
    <input
      type={type}
      value={value}
      onChange={onChange}
      placeholder={placeholder}
      className="w-full mt-1.5 rounded-xl border px-4 py-2.5 text-sm outline-none font-body"
      style={{ borderColor: "rgba(11,31,58,0.14)", color: NAVY }}
    />
  );
}

function TextArea({ value, onChange, placeholder, rows = 4 }) {
  return (
    <textarea
      value={value}
      onChange={onChange}
      placeholder={placeholder}
      rows={rows}
      className="w-full mt-1.5 rounded-xl border px-4 py-2.5 text-sm outline-none font-body resize-none"
      style={{ borderColor: "rgba(11,31,58,0.14)", color: NAVY }}
    />
  );
}

function Card({ title, kicker, children, action }) {
  return (
    <div className="rounded-2xl bg-white border border-gray-100 shadow-sm p-6 md:p-7">
      <div className="flex items-center justify-between mb-5 flex-wrap gap-3">
        <div>
          {kicker && <div className="font-mono text-xs uppercase tracking-wider mb-1" style={{ color: GOLD }}>{kicker}</div>}
          <h3 className="font-display text-lg font-semibold" style={{ color: NAVY }}>{title}</h3>
        </div>
        {action}
      </div>
      {children}
    </div>
  );
}

function SaveBar({ dirty, onSave }) {
  if (!dirty) return null;
  return (
    <div className="sticky bottom-4 flex justify-center z-20 mt-4">
      <div className="flex items-center gap-4 rounded-full px-5 py-3 shadow-lg" style={{ background: NAVY }}>
        <span className="text-xs text-white/70">You have unsaved changes</span>
        <button onClick={onSave} className="flex items-center gap-1.5 text-xs font-semibold px-4 py-2 rounded-full" style={{ background: GOLD, color: NAVY_DEEP }}>
          <Check size={13} /> Save changes
        </button>
      </div>
    </div>
  );
}

