  const [basics, setBasicsRaw] = useState({
    fullName: "Amaka Obi",
    headline: "Financial Analyst · 5 yrs experience",
    bio: "Financial analyst with a track record of building models that hold up under scrutiny.",
    city: "Lagos",
    country: "Nigeria",
    expectedSalaryMin: "500000",
    expectedSalaryMax: "700000",
    openToRemote: false,
  });
  const [education, setEducationRaw] = useState([
    { id: "1", institution: "University of Lagos", degree: "BSc", fieldOfStudy: "Economics", startDate: "2015-09-01", endDate: "2019-07-01" },
  ]);
  const [experience, setExperienceRaw] = useState([
    { id: "1", company: "Stanbic IBTC", title: "Financial Analyst", description: "Built monthly forecasting models.", startDate: "2020-02-01", isCurrent: true },
  ]);
  const [certifications, setCertificationsRaw] = useState([]);
  const [skills, setSkillsRaw] = useState(["Excel", "Power BI", "FP&A"]);
  const [industries, setIndustriesRaw] = useState(["Financial Services"]);

  const wrap = (setter) => (val) => { setter(val); setDirty(true); };
  const setBasics = wrap(setBasicsRaw);
  const setEducation = wrap(setEducationRaw);
  const setExperience = wrap(setExperienceRaw);
  const setCertifications = wrap(setCertificationsRaw);
  const setSkills = wrap(setSkillsRaw);
  const setIndustries = wrap(setIndustriesRaw);

  const handleSave = () => {
    // PATCH /candidates/me, PUT /candidates/me/skills, etc.
    setDirty(false);
  };

  return (
    <div className="min-h-screen font-body pb-24" style={{ background: GRAY_BG }}>
      {FONTS}
      <div className="max-w-5xl mx-auto px-5 md:px-8 pt-10">
        <h1 className="font-display text-2xl font-semibold" style={{ color: NAVY }}>Edit your profile</h1>
        <p className="text-sm text-gray-500 mt-1.5 mb-8">Changes save to your completion score immediately.</p>

        <div className="flex gap-8">
          <nav className="hidden md:flex flex-col gap-1 w-52 flex-shrink-0 sticky top-10 self-start">
            {SECTIONS.map((s) => {
              const Icon = s.icon;
              const isActive = active === s.key;
              return (
                <button
                  key={s.key}
                  onClick={() => setActive(s.key)}
                  className="flex items-center gap-2.5 px-4 py-2.5 rounded-xl text-sm font-medium text-left transition-colors"
                  style={{ background: isActive ? IVORY : "transparent", color: isActive ? NAVY : "#5b6572" }}
                >
