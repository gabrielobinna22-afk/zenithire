function ListEditor({ title, kicker, items, setItems, emptyLabel, renderForm, renderSummary, emptyDraft }) {
  const [editingId, setEditingId] = useState(null);
  const [draft, setDraft] = useState(emptyDraft);

  const startAdd = () => {
    setDraft(emptyDraft);
    setEditingId("new");
  };
  const startEdit = (item) => {
    setDraft(item);
    setEditingId(item.id);
  };
  const cancel = () => setEditingId(null);

  const save = () => {
    if (editingId === "new") {
      setItems([...items, { ...draft, id: crypto.randomUUID() }]);
    } else {
      setItems(items.map((i) => (i.id === editingId ? draft : i)));
    }
    setEditingId(null);
  };

  const remove = (id) => setItems(items.filter((i) => i.id !== id));

  return (
    <Card
      title={title}
      kicker={kicker}
      action={
        <button onClick={startAdd} className="flex items-center gap-1.5 text-xs font-semibold px-3.5 py-2 rounded-full" style={{ background: IVORY, color: GOLD }}>
          <Plus size={13} /> Add
        </button>
      }
    >
      <div className="space-y-3">
        {items.length === 0 && editingId !== "new" && (
          <p className="text-sm text-gray-400 italic py-4 text-center">{emptyLabel}</p>
        )}
        {items.map((item) =>
          editingId === item.id ? (
            <div key={item.id} className="rounded-xl border-2 p-4" style={{ borderColor: GOLD, background: IVORY }}>
              {renderForm(draft, setDraft)}
              <div className="flex gap-2 mt-4">
                <button onClick={save} className="text-xs font-semibold px-4 py-2 rounded-full" style={{ background: GOLD, color: NAVY_DEEP }}>Save</button>
                <button onClick={cancel} className="text-xs font-semibold px-4 py-2 rounded-full border border-gray-200">Cancel</button>
              </div>
            </div>
          ) : (
            <div key={item.id} className="flex items-start justify-between gap-3 p-4 rounded-xl" style={{ background: GRAY_BG }}>
              {renderSummary(item)}
              <div className="flex gap-2 flex-shrink-0">
                <button onClick={() => startEdit(item)} className="text-xs font-semibold" style={{ color: GOLD }}>Edit</button>
                <button onClick={() => remove(item.id)} className="text-gray-400 hover:text-red-500"><Trash2 size={14} /></button>
              </div>
            </div>
          )
        )}
        {editingId === "new" && (
          <div className="rounded-xl border-2 p-4" style={{ borderColor: GOLD, background: IVORY }}>
            {renderForm(draft, setDraft)}
            <div className="flex gap-2 mt-4">
              <button onClick={save} className="text-xs font-semibold px-4 py-2 rounded-full" style={{ background: GOLD, color: NAVY_DEEP }}>Add</button>
              <button onClick={cancel} className="text-xs font-semibold px-4 py-2 rounded-full border border-gray-200">Cancel</button>
            </div>
          </div>
        )}
      </div>
    </Card>
  );
}

