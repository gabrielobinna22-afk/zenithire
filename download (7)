                  {s.label}
                </button>
              ))}
            </div>

            {active === "basics" && <BasicsSection data={basics} setData={setBasics} />}
            {active === "education" && <EducationSection items={education} setItems={setEducation} />}
            {active === "experience" && <ExperienceSection items={experience} setItems={setExperience} />}
            {active === "certifications" && <CertificationsSection items={certifications} setItems={setCertifications} />}
            {active === "skills" && <SkillsSection skills={skills} setSkills={setSkills} industries={industries} setIndustries={setIndustries} />}
