function TagInput({ label, values, setValues, placeholder, max }) {
  const [draft, setDraft] = useState("");

  const add = () => {
    const v = draft.trim();
    if (v && !values.includes(v) && values.length < max) {
      setValues([...values, v]);
      setDraft("");
    }
  };

  return (
    <div>
      <Label>{label} ({values.length}/{max})</Label>
      <div className="flex flex-wrap gap-2 mt-2 mb-2">
        {values.map((v) => (
          <span key={v} className="flex items-center gap-1.5 text-xs font-medium px-3 py-1.5 rounded-full" style={{ background: IVORY, color: NAVY }}>
            {v}
            <button onClick={() => setValues(values.filter((x) => x !== v))}><X size={12} /></button>
          </span>
        ))}
      </div>
      <div className="flex gap-2">
        <input
          value={draft}
          onChange={(e) => setDraft(e.target.value)}
          onKeyDown={(e) => e.key === "Enter" && (e.preventDefault(), add())}
          placeholder={placeholder}
          className="flex-1 rounded-xl border px-4 py-2.5 text-sm outline-none"
          style={{ borderColor: "rgba(11,31,58,0.14)", color: NAVY }}
        />
        <button onClick={add} className="text-xs font-semibold px-4 py-2 rounded-full" style={{ background: GOLD, color: NAVY_DEEP }}>Add</button>
      </div>
    </div>
  );
}

