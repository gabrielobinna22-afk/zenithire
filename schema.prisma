// ============================================================================
// ZENITHIRE — DATABASE SCHEMA
// PostgreSQL via Prisma ORM
//
// Design notes:
// - Contact details are never exposed directly. Employers reach candidates
//   only through InterviewInvitation / Conversation, matching the
//   "invite-to-interview before contact" flow.
// - Every video goes through VideoStatus moderation before it's public.
// - Company accounts support multiple staff members (CompanyMember) rather
//   than tying a company to a single login, since real recruiting teams
//   share access.
// - Subscriptions and Payments are separate: a Subscription is the state
//   ("what plan, until when"), Payments are the transaction history that
//   funds it. This keeps invoice/receipt history intact even if a plan
//   changes.
// ============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// ENUMS
// ----------------------------------------------------------------------------

enum Role {
  CANDIDATE
  EMPLOYER
  ADMIN
}

enum AccountStatus {
  PENDING_VERIFICATION
  ACTIVE
  SUSPENDED
  BANNED
}

enum CompanyMemberRole {
  OWNER
  RECRUITER
}

enum CompanyStatus {
  PENDING
  VERIFIED
  REJECTED
  SUSPENDED
}

enum VideoStatus {
  PROCESSING
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  FREELANCE
}

enum WorkMode {
  REMOTE
  ON_SITE
  HYBRID
}

enum JobStatus {
  DRAFT
  PUBLISHED
  CLOSED
  EXPIRED
}

enum ApplicationStatus {
  SUBMITTED
  VIEWED
  SHORTLISTED
  REJECTED
  HIRED
  WITHDRAWN
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum MessageAttachmentType {
  IMAGE
  PDF
}

enum NotificationType {
  NEW_MESSAGE
  INTERVIEW_INVITE
  PROFILE_VIEW
  APPLICATION_UPDATE
  SUBSCRIPTION_EXPIRY
  PAYMENT
  VIDEO_APPROVED
  VIDEO_REJECTED
  COMPANY_VERIFIED
}

enum SubscriptionPlan {
  CANDIDATE_FREE
  CANDIDATE_PREMIUM
  EMPLOYER_FREE
  EMPLOYER_PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAST_DUE
}

enum PaymentProvider {
  PAYSTACK
  FLUTTERWAVE
  STRIPE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum ReportTargetType {
  CANDIDATE_PROFILE
  COMPANY
  JOB
  MESSAGE
}

enum ReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  DISMISSED
}

// ----------------------------------------------------------------------------
// AUTH / CORE USER
// ----------------------------------------------------------------------------

model User {
  id                String        @id @default(uuid())
  email             String        @unique
  passwordHash      String
  role              Role
  status            AccountStatus @default(PENDING_VERIFICATION)

  emailVerifiedAt   DateTime?
  emailVerifyToken  String?       @unique
  passwordResetToken String?      @unique
  passwordResetExpiresAt DateTime?

  refreshTokenHash  String?       // current valid refresh token, rotated on use
  lastLoginAt       DateTime?

  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  candidateProfile  CandidateProfile?
  companyMemberships CompanyMember[]

  savedJobs         SavedJob[]
  savedCandidates   SavedCandidate[]

  sentInvitations       InterviewInvitation[] @relation("InvitationsSent")
  receivedInvitations   InterviewInvitation[] @relation("InvitationsReceived")

  conversationsAsA  Conversation[] @relation("ConversationParticipantA")
  conversationsAsB  Conversation[] @relation("ConversationParticipantB")
  messages          Message[]

  notifications     Notification[]
  subscriptions     Subscription[]
  payments          Payment[]
  reportsFiled      Report[]       @relation("ReportsFiled")
  auditLogs         AuditLog[]
  blogPosts         BlogPost[]

  @@index([role, status])
}

// ----------------------------------------------------------------------------
// CANDIDATE SIDE
// ----------------------------------------------------------------------------

model CandidateProfile {
  id                String   @id @default(uuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName          String
  headline          String?               // e.g. "Financial Analyst · 5 yrs experience"
  photoUrl          String?
  cvUrl             String?
  cvFileName        String?

  bio               String?  @db.Text
  yearsExperience   Int?
  expectedSalaryMin Int?
  expectedSalaryMax Int?
  salaryCurrency    String   @default("NGN")
  availableFrom     DateTime?

  city              String?
  country           String?
  latitude          Float?
  longitude         Float?
  openToRemote      Boolean  @default(false)

  isFeatured        Boolean  @default(false)   // premium: featured profile
  profileViews      Int      @default(0)
  profileCompletion Int      @default(0)       // 0–100, recomputed on save

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  currentVideo      IntroVideo?  @relation("CurrentVideo", fields: [currentVideoId], references: [id])
  currentVideoId    String?      @unique
  videos            IntroVideo[] @relation("AllVideos")

  education         Education[]
  workExperience    WorkExperience[]
  certifications    Certification[]
  skills            CandidateSkill[]
  industries        CandidateIndustry[]

  applications      Application[]
  savedByEmployers  SavedCandidate[]
  invitationsReceived InterviewInvitation[] @relation("CandidateInvitations")

  @@index([city, country])
  @@index([isFeatured])
}

model IntroVideo {
  id           String      @id @default(uuid())
  candidateId  String
  candidate    CandidateProfile @relation("AllVideos", fields: [candidateId], references: [id], onDelete: Cascade)

  originalUrl  String
  playbackUrl  String?     // compressed/streaming-ready version
  thumbnailUrl String?
  durationSecs Int         // enforced <= 60 at upload time
  status       VideoStatus @default(PROCESSING)
  rejectionReason String?

  uploadedAt   DateTime    @default(now())
  reviewedAt   DateTime?
  reviewedById String?     // admin user id

  currentFor   CandidateProfile? @relation("CurrentVideo")

  @@index([status])
}

model Education {
  id            String   @id @default(uuid())
  candidateId   String
  candidate     CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  institution   String
  degree        String
  fieldOfStudy  String?
  startDate     DateTime
  endDate       DateTime?
  isOngoing     Boolean  @default(false)
}

model WorkExperience {
  id            String   @id @default(uuid())
  candidateId   String
  candidate     CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  company       String
  title         String
  description   String?  @db.Text
  startDate     DateTime
  endDate       DateTime?
  isCurrent     Boolean  @default(false)
}

model Certification {
  id            String    @id @default(uuid())
  candidateId   String
  candidate     CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  name          String
  issuer        String?
  issuedAt      DateTime?
  expiresAt     DateTime?
  credentialUrl String?
}

model Skill {
  id          String @id @default(uuid())
  name        String @unique
  candidates  CandidateSkill[]
  jobs        JobSkill[]
}

model CandidateSkill {
  candidateId String
  candidate   CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  skillId     String
  skill       Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([candidateId, skillId])
}

model Industry {
  id          String @id @default(uuid())
  name        String @unique
  candidates  CandidateIndustry[]
  jobs        Job[]
}

model CandidateIndustry {
  candidateId String
  candidate   CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  industryId  String
  industry    Industry @relation(fields: [industryId], references: [id], onDelete: Cascade)

  @@id([candidateId, industryId])
}

// ----------------------------------------------------------------------------
// EMPLOYER SIDE
// ----------------------------------------------------------------------------

model Company {
  id              String        @id @default(uuid())
  name            String
  slug            String        @unique
  logoUrl         String?
  description     String?       @db.Text
  website         String?
  industryTag     String?
  city            String?
  country          String?
  latitude        Float?
  longitude       Float?

  status          CompanyStatus @default(PENDING)
  rejectionReason String?
  isFeatured      Boolean       @default(false)

  registrationDocUrl String?    // uploaded for verification

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  members         CompanyMember[]
  jobs            Job[]
  savedCandidates SavedCandidate[]

  @@index([status])
}

model CompanyMember {
  id         String            @id @default(uuid())
  userId     String
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyId  String
  company    Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role       CompanyMemberRole @default(RECRUITER)
  joinedAt   DateTime          @default(now())

  @@unique([userId, companyId])
}

// ----------------------------------------------------------------------------
// JOBS
// ----------------------------------------------------------------------------

model Job {
  id               String         @id @default(uuid())
  companyId        String
  company          Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  postedById       String

  title            String
  description      String         @db.Text
  responsibilities String         @db.Text
  requirements     String         @db.Text

  salaryMin        Int?
  salaryMax        Int?
  salaryCurrency   String         @default("NGN")

  employmentType   EmploymentType
  workMode         WorkMode
  city             String?
  country          String?

  industryId       String?
  industry         Industry?      @relation(fields: [industryId], references: [id])
  categoryId       String?
  category         JobCategory?   @relation(fields: [categoryId], references: [id])

  applicationDeadline DateTime?
  status           JobStatus      @default(DRAFT)

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  skills           JobSkill[]
  applications     Application[]
  savedBy          SavedJob[]

  @@index([status, employmentType, workMode])
  @@index([city, country])
}

model JobCategory {
  id    String @id @default(uuid())
  name  String @unique
  jobs  Job[]
}

model JobSkill {
  jobId   String
  job     Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skillId String
  skill   Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([jobId, skillId])
}

model Application {
  id           String            @id @default(uuid())
  jobId        String
  job          Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidateId  String
  candidate    CandidateProfile  @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  status       ApplicationStatus @default(SUBMITTED)
  coverNote    String?           @db.Text

  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  invitation   InterviewInvitation?

  @@unique([jobId, candidateId])
  @@index([status])
}

model SavedJob {
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId     String
  job       Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  savedAt   DateTime @default(now())

  @@id([userId, jobId])
}

model SavedCandidate {
  companyId    String
  company      Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  candidateId  String
  candidate    CandidateProfile @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  savedById    String
  savedBy      User    @relation(fields: [savedById], references: [id], onDelete: Cascade)
  savedAt      DateTime @default(now())

  @@id([companyId, candidateId])
}

// ----------------------------------------------------------------------------
// INTERVIEW INVITATIONS
// Core privacy mechanism: no direct contact info exchange until accepted.
// ----------------------------------------------------------------------------

model InterviewInvitation {
  id             String           @id @default(uuid())

  applicationId  String?          @unique
  application    Application?     @relation(fields: [applicationId], references: [id])

  candidateId    String
  candidate      CandidateProfile @relation("CandidateInvitations", fields: [candidateId], references: [id], onDelete: Cascade)

  sentById       String           // employer user
  sentBy         User             @relation("InvitationsSent", fields: [sentById], references: [id])
  receivedById   String           // candidate's user id, for convenient inbox queries
  receivedBy     User             @relation("InvitationsReceived", fields: [receivedById], references: [id])

  message        String?          @db.Text
  proposedTimes  DateTime[]

  status         InvitationStatus @default(PENDING)
  respondedAt    DateTime?
  expiresAt      DateTime

  conversation   Conversation?

  createdAt      DateTime         @default(now())

  @@index([status])
}

// ----------------------------------------------------------------------------
// MESSAGING
// ----------------------------------------------------------------------------

model Conversation {
  id               String   @id @default(uuid())

  participantAId   String
  participantA     User     @relation("ConversationParticipantA", fields: [participantAId], references: [id])
  participantBId   String
  participantB     User     @relation("ConversationParticipantB", fields: [participantBId], references: [id])

  invitationId     String?  @unique
  invitation       InterviewInvitation? @relation(fields: [invitationId], references: [id])

  lastMessageAt    DateTime?
  createdAt        DateTime @default(now())

  messages         Message[]

  @@unique([participantAId, participantBId])
}

model Message {
  id             String    @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User      @relation(fields: [senderId], references: [id])

  body           String?   @db.Text
  attachmentUrl  String?
  attachmentType MessageAttachmentType?

  deliveredAt    DateTime  @default(now())
  readAt         DateTime?

  createdAt      DateTime  @default(now())

  @@index([conversationId, createdAt])
}

// ----------------------------------------------------------------------------
// NOTIFICATIONS
// ----------------------------------------------------------------------------

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String?
  linkUrl   String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
}

// ----------------------------------------------------------------------------
// SUBSCRIPTIONS & PAYMENTS
// ----------------------------------------------------------------------------

model Subscription {
  id           String             @id @default(uuid())
  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan         SubscriptionPlan
  status       SubscriptionStatus @default(ACTIVE)

  startedAt    DateTime           @default(now())
  currentPeriodEnd DateTime
  cancelAtPeriodEnd Boolean       @default(false)

  provider     PaymentProvider?
  providerSubscriptionId String?  // external subscription/reference id for auto-renewal

  payments     Payment[]

  @@index([userId, status])
}

model Payment {
  id               String        @id @default(uuid())
  userId           String
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscriptionId   String?
  subscription     Subscription? @relation(fields: [subscriptionId], references: [id])

  provider         PaymentProvider
  providerReference String       @unique
  amount           Int           // minor units (kobo / cents)
  currency         String        @default("NGN")
  status           PaymentStatus @default(PENDING)

  invoiceUrl       String?
  receiptUrl       String?

  createdAt        DateTime      @default(now())
  paidAt           DateTime?

  @@index([userId, status])
}

// ----------------------------------------------------------------------------
// TRUST & SAFETY
// ----------------------------------------------------------------------------

model Report {
  id           String           @id @default(uuid())
  filedById    String
  filedBy      User             @relation("ReportsFiled", fields: [filedById], references: [id])

  targetType   ReportTargetType
  targetId     String           // polymorphic reference (CandidateProfile.id / Company.id / Job.id / Message.id)
  reason       String
  details      String?          @db.Text

  status       ReportStatus     @default(OPEN)
  resolutionNote String?
  resolvedById String?
  resolvedAt   DateTime?

  createdAt    DateTime         @default(now())

  @@index([targetType, targetId])
  @@index([status])
}

model AuditLog {
  id         String   @id @default(uuid())
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id])
  action     String   // e.g. "VIDEO_APPROVED", "COMPANY_SUSPENDED"
  targetType String
  targetId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([targetType, targetId])
  @@index([actorId, createdAt])
}

// ----------------------------------------------------------------------------
// CONTENT: BLOG / ADS / SETTINGS
// ----------------------------------------------------------------------------

model BlogPost {
  id          String   @id @default(uuid())
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  title       String
  slug        String   @unique
  excerpt     String?
  content     String   @db.Text
  coverImageUrl String?
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Advertisement {
  id          String   @id @default(uuid())
  title       String
  imageUrl    String
  targetUrl   String
  placement   String   // e.g. "HOME_HERO_BANNER", "SEARCH_SIDEBAR"
  startsAt    DateTime
  endsAt      DateTime
  isActive    Boolean  @default(true)
  impressions Int      @default(0)
  clicks      Int      @default(0)
}

model SystemSetting {
  key         String   @id
  value       String   @db.Text
  updatedAt   DateTime @updatedAt
}
